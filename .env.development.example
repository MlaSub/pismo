# ============================================================
# Backend + Docker environment variables
# ============================================================
# Copy this file to .env.development and fill in the values.
# This file is used by docker-compose to configure the
# database and backend services.
# ============================================================

# PostgreSQL — used by both the database container and backend
POSTGRES_USER=           # e.g. postgres
POSTGRES_PASSWORD=       # choose a secure password
POSTGRES_DB=             # e.g. pismo

# Database connection — must match the Docker service name
DATABASE_HOST=database   # do not change when using docker-compose
DATABASE_PORT=5432        # do not change when using docker-compose

# App environment
ENVIROMENT=development

# LLM — Groq
LLM_PROVIDER=groq
LLM_CHAT_URL=https://api.groq.com/openai/v1
LLM_MODEL=               # e.g. llama-3.3-70b-versatile
LLM_NUM_THREADS=8
GROQ_API_KEY=            # get from console.groq.com
