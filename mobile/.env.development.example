# ============================================================
# Mobile (Expo) environment variables
# ============================================================
# Copy this file to .env.development and fill in the values.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the
# app and visible at runtime via process.env.
# ============================================================

# Backend API base URL
# - iOS simulator:   http://localhost:8000
# - Android emulator: http://10.0.2.2:8000
# - Real device:     http://<your-machine-LAN-IP>:8000
EXPO_PUBLIC_API_URL=
